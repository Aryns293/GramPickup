NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/grampickup
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=30d
CLIENT_ORIGIN=http://localhost:5173
ENABLE_FEE_SCHEDULER=true

# Admin credentials — set these before running seed. Keep private.
ADMIN_EMAIL=your-private-admin@email.com
ADMIN_PASSWORD=your-strong-admin-password

# Email (for forgot password). Use a Gmail App Password — not your real Gmail password.
# Setup: Google Account → Security → 2-Step Verification → App Passwords → Generate
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password

# Google OAuth — get from console.cloud.google.com
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
